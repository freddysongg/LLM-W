# Normalise line endings for all text files; keep LF in the working tree for Python/shell
* text=auto
*.py text eol=lf
*.sh text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.toml text eol=lf

.mulch/expertise/*.jsonl merge=union

.seeds/issues.jsonl merge=union
.seeds/templates.jsonl merge=union
.canopy/prompts.jsonl merge=union
.canopy/schemas.jsonl merge=union
